{
	"extends": "@tsconfig/node22/tsconfig.json",
	"compilerOptions": {
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"outDir": "./dist",
		"rootDir": "./src",
		"sourceMap": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"types": ["node", "jest"]
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/__tests__",
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/test"
	],
}